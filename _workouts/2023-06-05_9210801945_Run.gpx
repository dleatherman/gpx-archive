          <gpxtpx:hr>185</gpxtpx:hr>
          <gpxtpx:cad>55</gpxtpx:cad>
          <gpxtpx:speed>0.760</gpxtpx:speed>
        </gpxtpx:TrackPointExtension>
      </extensions>
    </trkpt>
    </trkseg>
  </trk>
</gpx>