---
title: Workouts
layout: base
permalink: /
showHeartRate: false
showMap: true
animate: true
---


{%- for workout in workouts | entries | reverse -%}
{#
  <!--For debugging purposes-->
  {{ workout | last | dump }}
#}
  {%- set entry = workout | last -%}
  {% if entry.features[0].geometry.coordinates.length > 1 %}
    <div class="workout-data-wrapper{% if animate %} animate{% endif %}">
      <dl>
        <dt>Date</dt>
        <dd>{{ entry.features[0].properties.time | readableDateISO }}</dd>
        {% if showHeartRate %}
        <dt>Heart Rate</dt>
        <dd>
          <div class="workout-data-graphs heart-rate">
            {{ workout | getSparklineFromWorkoutRecord('heartRates', 'currentColor') | safe }}
          </div>
        </dd>
        {% endif %}
      </dl>
      {# {{ entry.features[0] | dump }} #}
      {% if showMap %}
        {{ entry | CreateSVGfromGeoJSON | safe }}
      {% endif %}
    </div>
  {% endif %}
{%- endfor -%}

{% if animate %}
  {% include "io-workout-path.njk" %}
{% endif %}
